; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LANSHANProject"
config/name_localized={
"en": "LANSHANProject: An Unrecorded Story",
"zh": "火兰山中学"
}
config/description="LANSHANProject: An Unrecorded Story
"
config/version="3.0.0"
run/main_scene="res://scenes/SceneManager.tscn"
config/disable_project_settings_override=true
config/features=PackedStringArray("4.6")
config/icon="res://assets/icons/icon.png"
config/author="FuncWork Studios"

[audio]

buses/default_bus_layout=""
bus/master/bus_volume_db=0.0

[autoload]

EventBus="*res://scenes/autoload/EventBus.gd"
GameManager="*res://scenes/autoload/GameManager.gd"
AudioManager="*res://scenes/autoload/AudioManager.gd"
VNAudioService="*res://scenes/autoload/VNAudioService.gd"
MeowMcpBridge="*uid://c68oyvrc85sp8"

[debug]

shader_language/warnings/treat_warnings_as_errors=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/stretch/mode="canvas_items"
window/size/fullscreen=false

[editor_plugins]

enabled=PackedStringArray("res://addons/meow_godot_mcp/plugin.cfg")

[gdscript]

warnings/unsafe_property_access=true
warnings/unsafe_method_access=true
warnings/unsafe_cast=true
warnings/unsafe_call_argument=true

[gui]

theme/custom="res://themes/lsp_theme.tres"
theme/custom_font="res://assets/fonts/SourceHanSerifCN-Medium-6.otf"
theme/custom_font_size=16

