[gd_resource type="Theme" load_steps=7 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/times.ttf" id="1_times"]
[ext_resource type="FontFile" path="res://assets/fonts/SourceHanSerifCN-Medium-6.otf" id="2_serif"]
[ext_resource type="FontFile" path="res://assets/fonts/SourceHanSerifCN-SemiBold-7.otf" id="3_serif_bold"]
[ext_resource type="FontFile" path="res://assets/fonts/simfang.ttf" id="4_simfang"]
[ext_resource type="FontFile" path="res://assets/fonts/timesi.ttf" id="5_timesi"]

[resource]
; --- Default Font (Noto Serif SC / Source Han Serif for Chinese text) ---
default_font = ExtResource("2_serif")
default_font_size = 18

; --- Label Styles ---
Label/styles/normal = {
    "font": ExtResource("2_serif"),
    "font_size": 18,
    "font_color": Color(1, 1, 1, 1)
}

; --- RichTextLabel Styles ---
RichTextLabel/styles/normal = {
    "font": ExtResource("2_serif"),
    "font_size": 20,
    "font_color": Color(0, 0, 0, 1)
}

; --- Button Styles ---
Button/styles/normal = {
    "font": ExtResource("1_times"),
    "font_size": 16,
    "font_color": Color(1, 1, 1, 1)
}

; --- LineEdit Styles (for Registration name input) ---
LineEdit/styles/normal = {
    "font": ExtResource("2_serif"),
    "font_size": 24,
    "font_color": Color(0, 0, 0, 1)
}
